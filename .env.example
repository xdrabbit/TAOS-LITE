# --- Required ---
OPENAI_API_KEY=your_openai_api_key

# --- Speech-to-text (OpenAI) ---
# gpt-4o-transcribe (most accurate) | gpt-4o-mini-transcribe (cheaper) | whisper-1
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe

# --- Concept paraphrase (OpenAI) ---
OPENAI_PARAPHRASE_MODEL=gpt-4.1-mini

# --- Text-to-speech: ElevenLabs (default engine) ---
ELEVENLABS_API_KEY=your_elevenlabs_api_key
# Any voice works; eleven_turbo_v2_5 is multilingual + low latency.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL=eleven_turbo_v2_5
# Liz's cloned voice for Spanish->English output (defaults to this if unset).
ELEVENLABS_VOICE_ID_ES_EN=tpOaz7u8rY4nup9rRUmh

# --- Text-to-speech: OpenAI (alternate engine) ---
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=nova

# --- Supabase (auth + profiles/history) ---
# Public, safe-to-ship values (defaults are baked into the code):
NEXT_PUBLIC_SUPABASE_URL=https://duqkmuaceklnfgvoufrz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_LBhw7XTAhPWjNhbmjcf3uA_r_tbaALD
# SECRET — server only (Stripe webhook updates profiles). Do NOT prefix NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Stripe (paywall) ---
